---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Karina Elizondo" description="Page not found">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center">
      <p class="font-mono text-[11px] font-medium tracking-[0.2em] text-text-muted uppercase mb-4">404</p>
      <h1 class="font-display text-[28px] md:text-[36px] text-text-primary mb-3">Página no encontrada</h1>
      <p class="font-mono text-[13px] text-text-secondary mb-8">
        The page you're looking for doesn't exist.
      </p>
      <a
        href="/"
        class="inline-block font-mono text-[13px] font-medium tracking-[0.15em] text-dark bg-accent-ochre px-8 py-[14px] hover:bg-accent-ochre/80 transition-colors duration-200"
      >
        INICIO
      </a>
    </div>
  </main>
</BaseLayout>
