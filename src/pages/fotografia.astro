---
import BaseLayout from '../layouts/BaseLayout.astro';
import LanguageToggle from '../components/LanguageToggle.astro';

const photoList = [
  'danifya.webp', 'DSC00329.webp', 'DSC00402-Enhanced-NR.webp', 'DSC00485.webp',
  'DSC00541-2.webp', 'DSC00588.webp', 'DSC01256.webp', 'DSC02155-2.webp',
  'DSC03384.webp', 'DSC03826.webp', 'DSC03830.webp', 'DSC03854.webp',
  'DSC03959.webp', 'DSC04052.webp', 'DSC04107.webp', 'DSC04459.webp',
  'DSC04594.webp', 'DSC04622.webp', 'DSC04946.webp', 'DSC04956.webp',
  'DSC06970.webp', 'DSC07318.webp', 'DSC07702.webp', 'DSC08347.webp',
  'DSC08360.webp', 'DSC09374.webp', 'DSC09401.webp', 'DSC09589.webp',
  'DSC09619.webp', 'DSC09760.webp', 'DSC09954-2.webp', 'Espejo de Agua.webp',
  'Gestacion DSC00297.webp', 'Gestacion DSC01418-Enhanced-NR.webp', 'Gestacion DSC08346.webp', 'Gestacion DSC08627.webp',
  'IMG_3562.webp', 'Maternidades DSC00242.webp', 'Maternidades DSC01183.webp', 'Maternidades DSC07853__DSC07853.webp',
  'Maternidades DSC09738.webp', 'Maternidades DSC09921.webp', 'Medicina DSC06432.webp', 'Medicina DSC06617.webp',
  'Medicina DSC06639.webp', 'Medicina DSC06673.webp', 'Medicina DSC06870.webp', 'Renacer DSC01056.webp',
  'Renacer DSC01065.webp', 'Renacer DSC04560.webp', 'Resonare-03.webp', 'Resonare-06.webp',
  'Resonare-08.webp', 'Resonare-17.webp', 'gotita.webp', 'pezonlove.JPG.webp', 'quque.webp'
].sort();
---

<BaseLayout title="Fotografía — Karina Elizondo">
  <!-- Header with back link and language toggle -->
  <header class="fixed top-0 left-0 right-0 z-40 bg-dark/90 backdrop-blur-sm border-b border-border-warm">
    <div class="flex items-center justify-between px-6 py-4">
      <a href="/" class="flex items-center gap-2 text-text-primary hover:text-accent-ochre transition-colors">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        <span class="font-mono text-[13px] tracking-[1px]" data-es>VOLVER</span>
        <span class="font-mono text-[13px] tracking-[1px] hidden" data-en>BACK</span>
      </a>
      <LanguageToggle />
    </div>
  </header>

  <!-- Main content -->
  <main class="pt-24 pb-16">
    <section class="px-6 md:px-[120px] mb-12">
      <h1 class="font-display text-[28px] md:text-[40px] text-text-primary" data-es>Fotografía</h1>
      <h1 class="font-display text-[28px] md:text-[40px] text-text-primary hidden" data-en>Photography</h1>
    </section>
    
    <section class="px-6 md:px-[120px]">
      <div class="masonry">
        {photoList.map((photo) => (
          <button 
            type="button"
            class="gallery-image w-full mb-4 block cursor-zoom-in"
            data-img-src={`/photos/${photo}`}
          >
            <img 
              src={`/photos/${photo}`} 
              alt="" 
              loading="lazy"
              class="w-full block"
            />
          </button>
        ))}
      </div>
    </section>
  </main>
  
  <!-- Lightbox modal -->
  <div id="gallery-lightbox" class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-black/90" id="lightbox-backdrop"></div>
    <button id="lightbox-close" class="absolute top-6 right-6 text-white/70 hover:text-white transition-colors z-10">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain" />
  </div>
</BaseLayout>

<script>
function initGalleryLightbox() {
  const lightbox = document.getElementById('gallery-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const backdrop = document.getElementById('lightbox-backdrop');
  const closeBtn = document.getElementById('lightbox-close');
  
  document.querySelectorAll('.gallery-image').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-img-src');
      if (src && lightboxImg) {
        lightboxImg.src = src;
        lightbox?.classList.remove('opacity-0', 'pointer-events-none');
        lightbox?.classList.add('opacity-100', 'pointer-events-auto');
        document.body.style.overflow = 'hidden';
      }
    });
  });
  
  function close() {
    lightbox?.classList.remove('opacity-100', 'pointer-events-auto');
    lightbox?.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
    setTimeout(() => { if (lightboxImg) lightboxImg.src = ''; }, 300);
  }
  
  closeBtn?.addEventListener('click', close);
  backdrop?.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
}

initGalleryLightbox();
</script>

<style is:global>
.masonry {
  column-count: 1;
  column-gap: 1rem;
}
.masonry img {
  break-inside: avoid;
}
.gallery-image {
  background: none;
  padding: 0;
  border: none;
}
.gallery-image:hover img {
  opacity: 0.9;
}
@media (min-width: 640px) {
  .masonry { column-count: 2; }
}
@media (min-width: 1024px) {
  .masonry { column-count: 3; }
}
@media (min-width: 1280px) {
  .masonry { column-count: 4; }
}
</style>
