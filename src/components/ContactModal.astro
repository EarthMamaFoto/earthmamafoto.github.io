<div
  class="fixed inset-0 z-50 flex items-center justify-center transition-opacity duration-300 opacity-0 pointer-events-none"
  id="contact-modal"
>
  <div class="absolute inset-0 bg-black/80" id="contact-modal-backdrop"></div>

  <div class="relative w-full max-w-[440px] mx-4 bg-page p-8 md:p-10">
    <button
      class="absolute top-4 right-4 text-text-muted hover:text-text-primary transition-colors"
      id="contact-modal-close"
      aria-label="Close contact form"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>

    <form id="contact-form" class="flex flex-col gap-6">
      <h3 class="font-display text-[22px] text-text-primary">Colaboremos</h3>

      <div class="flex flex-col gap-1.5">
        <label for="contact-email" class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-muted uppercase">
          Email *
        </label>
        <input
          type="email"
          id="contact-email"
          name="email"
          required
          autocomplete="email"
          class="w-full bg-transparent border-b border-border-warm pb-2 text-[15px] text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:border-accent-ochre transition-colors"
          placeholder="tu@email.com"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-phone" class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-muted uppercase">
          Teléfono
        </label>
        <input
          type="tel"
          id="contact-phone"
          name="phone"
          autocomplete="tel"
          class="w-full bg-transparent border-b border-border-warm pb-2 text-[15px] text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:border-accent-ochre transition-colors"
          placeholder="+506 ..."
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="contact-message" class="font-mono text-[11px] font-medium tracking-[0.15em] text-text-muted uppercase">
          Mensaje
        </label>
        <textarea
          id="contact-message"
          name="message"
          rows="3"
          class="w-full bg-transparent border-b border-border-warm pb-2 text-[15px] text-text-primary placeholder:text-text-muted/50 focus:outline-none focus:border-accent-ochre transition-colors resize-none"
          placeholder="Cuéntame sobre tu proyecto..."
        ></textarea>
      </div>

      <div id="contact-form-error" class="hidden text-[13px] text-accent-sienna"></div>

      <div id="contact-form-success" class="hidden flex flex-col items-center gap-3 py-4">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-ochre">
          <polyline points="20 6 9 17 4 12" />
        </svg>
        <p class="font-mono text-[13px] text-text-secondary" data-es>Gracias, te escribiré pronto.</p>
        <p class="font-mono text-[13px] text-text-secondary hidden" data-en>Thank you, I'll get back to you soon.</p>
      </div>

      <button
        type="submit"
        id="contact-form-submit"
        class="mt-1 w-full bg-dark text-white font-mono text-[13px] font-medium tracking-[0.15em] py-[14px] hover:bg-dark/80 transition-colors duration-200 disabled:opacity-40 disabled:cursor-not-allowed"
      >
        ENVIAR
      </button>
    </form>
  </div>
</div>
