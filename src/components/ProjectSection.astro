---
import VideoPlaceholder from './VideoPlaceholder.astro';
import ProjectLinks from './ProjectLinks.astro';

interface Props {
  index: number;
  title?: string;
  titleEn?: string;
  description?: string;
  descriptionEn?: string;
  order?: number;
  videoUrl?: string;
  mediaType?: string;
  thumbnail?: string;
  links?: Array<{ title: string; url: string; type?: string }>;
}

const {
  index,
  title = '',
  titleEn = '',
  description = '',
  descriptionEn = '',
  order,
  videoUrl = '',
  mediaType = '',
  thumbnail = '',
  links = [],
} = Astro.props;

const isEven = index % 2 === 1;
const displayNumber = String(order || index + 1).padStart(2, '0');
---

<section class="w-full py-10 md:py-[60px] px-6 md:px-[120px] border-b border-border-warm flex flex-col md:flex-row items-center gap-6 md:gap-[60px]">
  {isEven ? (
    <>
      <div class="flex-1 flex flex-col gap-4 md:gap-5 justify-center max-w-[500px] order-2 md:order-1">
        <span class="font-mono text-[13px] font-medium tracking-[2px] text-accent-ochre">
          {displayNumber}
        </span>
        <h2 class="font-display text-[28px] md:text-[36px] leading-tight text-text-primary" data-es>{title}</h2>
        {titleEn && <h2 class="font-display text-[28px] md:text-[36px] leading-tight text-text-primary hidden" data-en>{titleEn}</h2>}
        <p class="text-[15px] leading-[1.6] text-text-secondary" data-es>{description}</p>
        {descriptionEn && <p class="text-[15px] leading-[1.6] text-text-secondary hidden" data-en>{descriptionEn}</p>}
        <ProjectLinks links={links} />
      </div>
      <div class="w-full order-1 md:order-2">
        <VideoPlaceholder videoUrl={videoUrl} mediaType={mediaType} thumbnail={thumbnail} />
      </div>
    </>
  ) : (
    <>
      <div class="w-full order-1">
        <VideoPlaceholder videoUrl={videoUrl} mediaType={mediaType} thumbnail={thumbnail} />
      </div>
      <div class="flex-1 flex flex-col gap-4 md:gap-5 justify-center max-w-[500px] order-2">
        <span class="font-mono text-[13px] font-medium tracking-[2px] text-accent-ochre">
          {displayNumber}
        </span>
        <h2 class="font-display text-[28px] md:text-[36px] leading-tight text-text-primary" data-es>{title}</h2>
        {titleEn && <h2 class="font-display text-[28px] md:text-[36px] leading-tight text-text-primary hidden" data-en>{titleEn}</h2>}
        <p class="text-[15px] leading-[1.6] text-text-secondary" data-es>{description}</p>
        {descriptionEn && <p class="text-[15px] leading-[1.6] text-text-secondary hidden" data-en>{descriptionEn}</p>}
        <ProjectLinks links={links} />
      </div>
    </>
  )}
</section>
