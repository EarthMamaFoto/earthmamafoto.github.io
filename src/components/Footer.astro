---
interface Props {
  footerQuoteTitleEs?: string;
  footerQuoteTitleEn?: string;
  footerQuoteEs?: string;
  footerQuoteEn?: string;
  colaboremosEmail?: string;
  socialLinks?: Array<{ platform: string; url: string }>;
}
const {
  footerQuoteTitleEs = '\u00AB Gratitud al reconocimiento \u00BB',
  footerQuoteTitleEn = '\u00AB Gratitude for the recognition \u00BB',
  footerQuoteEs = 'Mi intenci\u00F3n es mostrar una pincelada de proyectos en los que he dirigido, colaborado o participado con mucho amor y dedicaci\u00F3n.',
  footerQuoteEn = 'My intention is to show a glimpse of projects I have directed, collaborated on, or participated in with much love and dedication.',
  colaboremosEmail = '',
  socialLinks = [],
} = Astro.props;

const emailHref = colaboremosEmail ? `mailto:${colaboremosEmail}` : '#';

function socialIcon(platform: string): string {
  switch (platform) {
    case 'instagram':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>`;
    case 'twitter':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`;
    case 'linkedin':
      return `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>`;
    default:
      return '';
  }
}
---

<footer class="w-full py-12 md:py-20 px-6 md:px-[120px] border-t border-border-warm flex flex-col items-center gap-8 md:gap-12">
  <div class="max-w-[800px] flex flex-col items-center gap-6 text-center">
    <p class="font-display text-[18px] md:text-[22px] text-text-primary" data-es>{footerQuoteTitleEs}</p>
    <p class="font-display text-[18px] md:text-[22px] text-text-primary hidden" data-en>{footerQuoteTitleEn}</p>
    <p class="text-[15px] leading-[1.6] text-text-secondary max-w-[700px]" data-es>{footerQuoteEs}</p>
    <p class="text-[15px] leading-[1.6] text-text-secondary max-w-[700px] hidden" data-en>{footerQuoteEn}</p>
  </div>

  <a
    href={emailHref}
    class="inline-flex items-center gap-2.5 bg-dark px-9 py-[18px] text-white font-mono text-[13px] font-medium tracking-[0.15em] hover:bg-dark/80 transition-colors duration-200"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect width="20" height="16" x="2" y="4" rx="2" />
      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
    </svg>
    <span>COLABOREMOS</span>
  </a>

  {socialLinks.length > 0 && (
    <div class="flex gap-8">
      {socialLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-text-tertiary hover:text-text-secondary transition-colors duration-200"
          aria-label={link.platform}
        >
          <Fragment set:html={socialIcon(link.platform)} />
        </a>
      ))}
    </div>
  )}
</footer>
