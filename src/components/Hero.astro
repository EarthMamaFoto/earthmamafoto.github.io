---
import LanguageToggle from './LanguageToggle.astro';

interface Props {
  heroName?: string;
  heroRoleEs?: string;
  heroRoleEn?: string;
  heroTaglineEs?: string;
  heroTaglineEn?: string;
}

const {
  heroName = 'Karina Elizondo',
  heroRoleEs = 'ESTRATEGA CREATIVA Y PRODUCTORA DE VIDEO',
  heroRoleEn = 'CREATIVE STRATEGIST & VIDEO PRODUCER',
  heroTaglineEs = 'Estrategia de Contenido · Producción de Video · Narrativa de Marca',
  heroTaglineEn = 'Content Strategy · Video Production · Brand Storytelling',
} = Astro.props;
---

<section class="relative w-full h-screen bg-dark overflow-hidden" id="hero">
  <div class="video-bg">
    <div
      class="video-bg__poster bg-[#382F28]"
      id="hero-poster"
      style="background-image: url('https://img.youtube.com/vi/WhVFpTtQcjE/maxresdefault.jpg')"
    ></div>
    <iframe
      id="hero-video"
      src="https://www.youtube.com/embed/WhVFpTtQcjE?autoplay=1&mute=1&loop=1&playlist=WhVFpTtQcjE&controls=0&rel=0&modestbranding=1&playsinline=1&enablejsapi=1&iv_load_policy=3"
      allow="autoplay; encrypted-media"
      loading="eager"
    ></iframe>
  </div>

  <div class="absolute inset-0 bg-gradient-to-b from-dark/20 via-dark/80 to-dark"></div>

  <!-- Language toggle — top right -->
  <div class="absolute top-6 right-6 md:top-10 md:right-[120px]">
    <LanguageToggle />
  </div>

  <div class="absolute bottom-10 left-6 md:bottom-[120px] md:left-[120px] flex flex-col gap-3 md:gap-4">
    <h1 class="font-display text-[40px] md:text-hero leading-[1.05] tracking-hero text-white">
      {heroName}
    </h1>
    <p
      class="font-mono text-label font-medium tracking-subtitle text-white/70"
      data-es
    >
      {heroRoleEs}
    </p>
    <p
      class="font-mono text-label font-medium tracking-subtitle text-white/70 hidden"
      data-en
    >
      {heroRoleEn}
    </p>
    <p class="font-mono text-tagline tracking-label text-white/50" data-es>
      {heroTaglineEs}
    </p>
    <p
      class="font-mono text-tagline tracking-label text-white/50 hidden"
      data-en
    >
      {heroTaglineEn}
    </p>
  </div>

  <!-- Scroll indicator — bottom center -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 text-white/25">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </div>
</section>
