---
<div class="inline-flex items-center gap-0 cursor-pointer select-none" id="lang-toggle">
  <span class="lang-es font-mono text-[13px] font-medium tracking-[1px] text-white opacity-100 transition-opacity duration-200" data-lang="es">ES</span>
  <span class="font-mono text-[13px] text-white opacity-40">|</span>
  <span class="lang-en font-mono text-[13px] font-medium tracking-[1px] text-white opacity-40 transition-opacity duration-200" data-lang="en">EN</span>
</div>

<style>
  #lang-toggle [data-lang].active {
    opacity: 1 !important;
  }
  #lang-toggle [data-lang]:not(.active) {
    opacity: 0.4 !important;
  }
</style>

<script>
  import { initLocale, toggleLocale, getLocale } from '../scripts/language';

  const toggle = document.getElementById('lang-toggle');
  const esSpan = toggle?.querySelector('[data-lang="es"]');
  const enSpan = toggle?.querySelector('[data-lang="en"]');

  function applyLocale(locale: string): void {
    const isEn = locale === 'en';

    // Toggle [data-es] elements — add/remove 'hidden' class
    document.querySelectorAll('[data-es]').forEach((el: Element) => {
      el.classList.toggle('hidden', isEn);
      (el as HTMLElement).style.display = '';
    });

    // Toggle [data-en] elements — add/remove 'hidden' class
    document.querySelectorAll('[data-en]').forEach((el: Element) => {
      el.classList.toggle('hidden', !isEn);
      (el as HTMLElement).style.display = '';
    });

    // Update toggle button UI
    esSpan?.classList.toggle('active', !isEn);
    enSpan?.classList.toggle('active', isEn);
  }

  // Initialize: restore saved locale on page load
  initLocale();
  applyLocale(getLocale());

  // Listen for programmatic locale changes
  document.addEventListener('locale-change', ((e: CustomEvent) => {
    applyLocale(e.detail.locale);
  }) as EventListener);

  // Click handler
  toggle?.addEventListener('click', () => {
    const newLocale = toggleLocale();
    applyLocale(newLocale);
  });
</script>
